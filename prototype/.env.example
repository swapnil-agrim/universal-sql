# Copy to .env and adjust as needed (docker-compose reads it automatically).

# Connector mode: "mock" (deterministic) or "live" (hits real GitHub/Jira)
CONNECTOR_MODE=mock

# For CONNECTOR_MODE=live only — leave blank in mock mode
GITHUB_TOKEN=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_TOKEN=

# Rate-limit budgets (per minute) per scope
GITHUB_RPM_GLOBAL=1200
GITHUB_RPM_TENANT=600
GITHUB_RPM_USER=300
JIRA_RPM_GLOBAL=1200
JIRA_RPM_TENANT=600
JIRA_RPM_USER=300

# Default cache TTL (seconds)
DEFAULT_TTL_SECONDS=300
