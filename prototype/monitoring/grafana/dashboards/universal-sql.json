{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "type": "stat",
      "title": "Queries / second (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "blue", "value": 100 }
          ]},
          "unit": "reqps"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      },
      "targets": [
        { "expr": "sum(rate(queries_total[30s]))", "refId": "A", "legendFormat": "QPS" }
      ]
    },
    {
      "type": "stat",
      "title": "P95 connector latency (live fetch)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 1.5 }
          ]},
          "unit": "s"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(connector_request_duration_seconds_bucket{cache_status=\"miss\"}[1m])))",
          "refId": "A",
          "legendFormat": "P95 (live)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Cache hit ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "green", "value": 0.9 }
          ]},
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "sum(rate(connector_request_duration_seconds_count{cache_status=\"hit\"}[1m])) / clamp_min(sum(rate(connector_request_duration_seconds_count[1m])), 0.0001)",
          "refId": "A",
          "legendFormat": "Hit ratio"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Rate-limit rejections (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.1 }
          ]},
          "unit": "reqps"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value"
      },
      "targets": [
        { "expr": "sum(rate(rate_limit_rejections_total[1m]))", "refId": "A", "legendFormat": "rejections/s" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connector latency P50 / P95 by cache status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, connector, cache_status) (rate(connector_request_duration_seconds_bucket[30s])))",
          "refId": "A",
          "legendFormat": "P50 {{connector}} ({{cache_status}})"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, connector, cache_status) (rate(connector_request_duration_seconds_bucket[30s])))",
          "refId": "B",
          "legendFormat": "P95 {{connector}} ({{cache_status}})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Throughput (queries / second)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": { "mode": "normal" } },
          "unit": "reqps"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (result) (rate(queries_total[15s]))",
          "refId": "A",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connector fetch volume (hit vs miss)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": { "mode": "normal" } },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (connector, cache_status) (rate(connector_request_duration_seconds_count[15s]))",
          "refId": "A",
          "legendFormat": "{{connector}} {{cache_status}}"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
